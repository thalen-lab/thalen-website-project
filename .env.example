# ============================================
# Thalen Technologies - Environment Variables
# ============================================
# Copy this to .env for local development.
# On Railway, set these in the service Variables tab.

# --- REQUIRED ---

# Node environment (Railway sets this automatically)
NODE_ENV=production

# Port (Railway provides this automatically via $PORT)
# PORT=3000

# MySQL connection string (Railway MySQL plugin provides this automatically as DATABASE_URL)
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/thalen

# JWT secret for session cookies (generate a strong random string)
# Example: openssl rand -base64 32
JWT_SECRET=change-me-to-a-strong-random-string

# --- OPTIONAL (features disabled without these) ---

# Manus OAuth (disabled for now - leave empty)
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
# VITE_APP_ID=
# OWNER_OPEN_ID=

# Manus Forge API (storage, notifications, LLM - disabled for now)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@thalentechnologies.com

# Client-side VAPID key (must match VAPID_PUBLIC_KEY above)
# VITE_VAPID_PUBLIC_KEY=

# App title shown in the browser tab
VITE_APP_TITLE=Thalen Technologies

# Umami Analytics (optional - leave empty to disable)
# VITE_ANALYTICS_ENDPOINT=https://your-umami-instance.com
# VITE_ANALYTICS_WEBSITE_ID=your-website-id
